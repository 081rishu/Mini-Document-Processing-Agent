# --- Required ---
OPENAI_API_KEY=sk-...

# --- Models (cost tiering) ---
CLASSIFY_MODEL=gpt-4o-mini
EXTRACT_MODEL=gpt-4o-mini
VERIFY_MODEL=gpt-4o
VISION_MODEL=gpt-4o

# --- Ingest / page triage ---
# A PDF page with fewer than this many tokens of extractable text is treated as
# an "image page" and routed to the vision collage. Tuned empirically on real docs.
IMAGE_PAGE_MIN_TOKENS=50

# --- Confidence gating ---
# Documents whose composite classification confidence falls below this are flagged
# for human review. Range 0.0-1.0.
CLASSIFY_CONFIDENCE_THRESHOLD=0.6
# Extracted fields whose grounding confidence falls below this are flagged.
FIELD_CONFIDENCE_THRESHOLD=0.5

# --- Concurrency & limits ---
MAX_CONCURRENCY=5
MAX_BATCH_FILES=25
MAX_FILE_MB=15

# --- LLM robustness ---
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=60
